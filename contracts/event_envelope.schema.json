    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "thread_id": {
      "title": "Thread Id",
      "type": "string"
    },
    "seq": {
      "title": "Seq",
      "type": "integer"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    },
    "data": {
      "additionalProperties": true,
      "title": "Data",
      "type": "object"
    }
  },
  "required": [
    "event",
    "run_id",
    "thread_id",
    "seq"
